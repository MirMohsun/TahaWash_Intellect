# ─────────────────────────────────────────────────────────
# Tahawash — git attributes for consistent line endings
# ─────────────────────────────────────────────────────────

# Default: auto-normalize text files to LF in repo, native in checkout
* text=auto eol=lf

# Source code → always LF
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.mjs text eol=lf
*.cjs text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.md text eol=lf
*.css text eol=lf
*.scss text eol=lf
*.html text eol=lf

# Shell scripts → always LF (must be Unix-line-ending)
*.sh text eol=lf

# Windows-specific files → CRLF
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Binary files (do not touch)
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
*.avif binary
*.pdf binary
*.zip binary
*.tar.gz binary
*.woff binary
*.woff2 binary
*.ttf binary
*.otf binary
*.eot binary
*.mp4 binary
*.mp3 binary
*.wav binary

# Lock files → LF, never merge
pnpm-lock.yaml -merge linguist-generated=true text eol=lf
package-lock.json -merge linguist-generated=true text eol=lf
yarn.lock -merge linguist-generated=true text eol=lf
