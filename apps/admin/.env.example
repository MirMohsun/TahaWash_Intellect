# Tahawash admin — example environment.
# Copy to apps/admin/.env.local (gitignored) and adjust.
#
# Vite freezes these into the JS bundle at BUILD TIME. They are NOT
# read at runtime. To change them, rebuild + redeploy. (In Railway,
# changing a VITE_* variable triggers a fresh build automatically.)

# ─── Backend URL ────────────────────────────────────────────────
# REQUIRED — base URL of the deployed backend.
VITE_API_URL=http://localhost:3000

# ─── Mapbox token (optional but recommended) ────────────────────
# Free tier covers ~50k map loads/month. Get one at
# https://account.mapbox.com/access-tokens/ — public scopes only.
VITE_MAPBOX_TOKEN=

# ─── Error tracking + analytics (optional) ──────────────────────
VITE_SENTRY_DSN=
VITE_POSTHOG_API_KEY=
