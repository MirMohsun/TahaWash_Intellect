# Tahawash mobile — example public environment variables.
# Copy to apps/mobile/.env (gitignored) and adjust for local Expo Go runs.
#
# IMPORTANT: only EXPO_PUBLIC_* vars are exposed to runtime JS.
# Everything else is build-time only and lives inside eas.json `env` blocks
# (per-profile: development / preview / staging / production).
#
# EAS BUILDS read from eas.json env (NOT from this .env file).
# Local `pnpm dev` (Expo Go) reads from this .env file.

# ─── Backend URL ────────────────────────────────────────────────
# For local Expo Go on your phone, use your computer's LAN IP, not localhost
# (the phone can't reach 127.0.0.1 of the computer).
# Example: EXPO_PUBLIC_API_URL=http://192.168.1.50:3000
EXPO_PUBLIC_API_URL=http://localhost:3000

# ─── Mapbox token ───────────────────────────────────────────────
EXPO_PUBLIC_MAPBOX_TOKEN=

# ─── Error tracking + analytics (optional) ──────────────────────
EXPO_PUBLIC_SENTRY_DSN=
EXPO_PUBLIC_POSTHOG_API_KEY=

# ─── Support contact (used in mobile WhatsApp links) ────────────
# Should match super-admin's PlatformSetting `support.whatsappNumber`.
# Defaulted in code; this just overrides for local testing.
EXPO_PUBLIC_SUPPORT_WHATSAPP=
