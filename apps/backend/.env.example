# Tahawash backend — example environment.
# Copy to apps/backend/.env (gitignored) and adjust for your environment.
# In Railway, paste each KEY=value line into the service's Variables tab.

NODE_ENV=development
PORT=3000

# ─── Database ───────────────────────────────────────────────────
# Docker Compose maps host 5434 → container 5432 to avoid clashing
# with any other PostgreSQL already running on the host.
# In Railway, this is auto-injected as the DATABASE_URL reference
# variable from the Postgres service.
DATABASE_URL=postgresql://postgres:postgres@localhost:5434/tahawash

# ─── Redis (BullMQ + caching) ───────────────────────────────────
# In Railway, this is auto-injected as the REDIS_URL reference
# variable from the Redis service.
REDIS_URL=redis://localhost:6379

# ─── JWT secrets ────────────────────────────────────────────────
# Generate strong random values for staging/prod. Locally, any 16+ char string works.
# Example: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_ACCESS_SECRET=dev-access-secret-please-change-to-strong-random-value
JWT_REFRESH_SECRET=dev-refresh-secret-please-change-to-strong-random-value
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=30d

# ─── SMS provider for OTP ───────────────────────────────────────
# `mock` logs OTP codes to the server console (dev only).
# Production options: `albatros` | `lifecell` (not yet implemented).
SMS_PROVIDER=mock
SMS_API_KEY=
SMS_SENDER_ID=Tahawash

# ─── Push notifications ─────────────────────────────────────────
# `mock` logs to console; `fcm` uses Firebase Cloud Messaging.
PUSH_PROVIDER=mock
FCM_SERVICE_ACCOUNT_JSON=

# ─── Email (transactional) ──────────────────────────────────────
# `mock` logs to console; `resend` posts to the Resend API.
EMAIL_PROVIDER=mock
RESEND_API_KEY=
EMAIL_FROM=Tahawash <noreply@tahawash.az>

# ─── Public-facing URLs (used in links / deep-links) ────────────
# In prod, point at the deployed customer + admin domains.
PUBLIC_APP_URL=https://app.tahawash.az
ADMIN_APP_URL=http://localhost:5173

# ─── CORS allowlist ─────────────────────────────────────────────
# Comma-separated list of allowed origins (no trailing slash).
# In prod, set this to the deployed admin URL(s) so nothing else can
# call this API from a browser.
# Example: https://admin.tahawash.az,https://staging-admin.tahawash.az
CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# ─── Cloudflare R2 (object storage for logos / photos / promo images) ──
# All five are OPTIONAL — leave blank and the uploads endpoints return a
# clean 503 ("uploads disabled"); the rest of the app still boots.
# Where to find each (Cloudflare dashboard → R2):
#   R2_ACCOUNT_ID        Account ID shown at the top of the R2 overview page.
#   R2_ACCESS_KEY_ID }   From an R2 API token. The token needs "Object Read &
#   R2_SECRET_ACCESS_KEY}  Write"; for AUTOMATIC bucket-CORS setup on boot it
#                          also needs bucket-settings permission ("Admin Read
#                          & Write") — otherwise set CORS by hand (see
#                          src/modules/uploads/README.md).
#   R2_BUCKET            Bucket name, e.g. tahawash-uploads.
#   R2_PUBLIC_BASE_URL   What gets stored in the DB + served to clients. Use
#                        the bucket's public r2.dev URL OR a connected custom
#                        domain (https://cdn.tahawash.az). NO trailing slash.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_BASE_URL=

# ─── Integration tests (optional, only for pnpm test:integration) ──
# Separate DB on the same Postgres instance so tests can wipe rows
# without touching dev data. Create the database ONCE:
#   docker compose exec postgres psql -U postgres -c "CREATE DATABASE tahawash_test;"
# Then `pnpm test:integration` migrates + seeds + runs the test suite.
TEST_DATABASE_URL=postgresql://postgres:postgres@localhost:5434/tahawash_test
