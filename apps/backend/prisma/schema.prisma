// ════════════════════════════════════════════════════════════════════════════
// Tahawash — Prisma schema (Phase 1.1)
//
// Conventions:
//   - cuid() string IDs (sortable, URL-safe, no DB pre-fill)
//   - snake_case table names via @@map
//   - ISO timestamps via DateTime (createdAt + updatedAt on most tables)
//   - Decimal(10,2) for AZN money (NEVER use Float for currency)
//   - tenant_id index on every tenant-scoped table (multi-tenancy)
//   - deletedAt for soft-delete on Tenant + Customer + Location (tax retention)
//   - PostGIS extension enabled for geo queries on Location.geom
// ════════════════════════════════════════════════════════════════════════════

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  // PostGIS + the support extensions bundled with the postgis/postgis Docker
  // image. We declare all of them so Prisma detects no drift.
  extensions = [postgis, fuzzystrmatch, postgis_tiger_geocoder, postgis_topology]
}

// ════════════════════════════════════════════════════════════════════════════
// AUTH — Super-admin
// ════════════════════════════════════════════════════════════════════════════

model SuperAdminUser {
  id            String                   @id @default(cuid())
  username      String                   @unique
  email         String                   @unique
  passwordHash  String
  fullName      String
  lastLoginAt   DateTime?
  createdAt     DateTime                 @default(now())
  updatedAt     DateTime                 @updatedAt
  refreshTokens SuperAdminRefreshToken[]

  @@map("super_admin_users")
}

model SuperAdminRefreshToken {
  id        String         @id @default(cuid())
  userId    String
  user      SuperAdminUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String         @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime       @default(now())

  @@index([userId])
  @@map("super_admin_refresh_tokens")
}

// ════════════════════════════════════════════════════════════════════════════
// AUTH — Tenant owner (one user per tenant in MVP)
// ════════════════════════════════════════════════════════════════════════════

model TenantUser {
  id                     String               @id @default(cuid())
  tenantId               String               @unique
  tenant                 Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  username               String               @unique
  passwordHash           String
  lastLoginAt            DateTime?
  passwordResetToken     String?              @unique
  passwordResetExpiresAt DateTime?
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt
  refreshTokens          TenantRefreshToken[]

  @@map("tenant_users")
}

model TenantRefreshToken {
  id        String     @id @default(cuid())
  userId    String
  user      TenantUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String     @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime   @default(now())

  @@index([userId])
  @@map("tenant_refresh_tokens")
}

// ════════════════════════════════════════════════════════════════════════════
// AUTH — Customer (phone + OTP)
// ════════════════════════════════════════════════════════════════════════════

model OtpCode {
  // Phone-OTP records. Code stored as hash; expires after 5 minutes;
  // max 5 verify attempts per row before locked (spec).
  id            String    @id @default(cuid())
  phone         String
  codeHash      String
  expiresAt     DateTime
  attemptsCount Int       @default(0)
  consumedAt    DateTime?
  createdAt     DateTime  @default(now())

  @@index([phone, createdAt(sort: Desc)])
  @@map("otp_codes")
}

model CustomerRefreshToken {
  id         String    @id @default(cuid())
  customerId String
  customer   Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  tokenHash  String    @unique
  expiresAt  DateTime
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())

  @@index([customerId])
  @@map("customer_refresh_tokens")
}

// ════════════════════════════════════════════════════════════════════════════
// TENANT
// ════════════════════════════════════════════════════════════════════════════

enum TenantStatus {
  pending
  active
  suspended
  hidden
}

model Tenant {
  id                String       @id @default(cuid())
  brandName         String
  legalName         String
  voen              String       @unique
  ownerName         String
  ownerEmail        String
  ownerPhone        String
  ePointMerchantId  String?
  themeColor        String       @default("#0E7AE7")
  logoUrl           String?
  descriptionAz     String?      @db.Text
  descriptionRu     String?      @db.Text
  descriptionEn     String?      @db.Text
  contactPhone      String?
  minChargeAmount   Decimal      @default("1.00") @db.Decimal(10, 2)
  chargeStep        Decimal      @default("0.50") @db.Decimal(10, 2)
  status            TenantStatus @default(pending)
  subscriptionStart DateTime?
  subscriptionEnd   DateTime?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  user            TenantUser?
  locations       Location[]
  photos          TenantPhoto[]
  services        ServiceDisplay[]
  subscriptions   Subscription[]
  transactions    Transaction[]
  bays            Bay[]
  favorites       Favorite[]
  featured        FeaturedTenant?
  hardwareEvents  HardwareEvent[]

  @@index([status])
  @@index([deletedAt])
  @@map("tenants")
}

model TenantPhoto {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  url       String
  sortOrder Int      @default(0)
  isHero    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([tenantId, sortOrder])
  @@map("tenant_photos")
}

model ServiceDisplay {
  id        String  @id @default(cuid())
  tenantId  String
  tenant    Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  iconKey   String
  labelAz   String
  labelRu   String?
  labelEn   String?
  sortOrder Int     @default(0)

  @@index([tenantId, sortOrder])
  @@map("service_displays")
}

model Subscription {
  // Manual subscription payment log (super-admin records these).
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  amountAzn   Decimal  @db.Decimal(10, 2)
  paidAt      DateTime
  periodStart DateTime
  periodEnd   DateTime
  method      String // "bank_transfer" | "cash" | "other"
  notes       String?  @db.Text
  recordedBy  String // super-admin user id
  createdAt   DateTime @default(now())

  @@index([tenantId, paidAt(sort: Desc)])
  @@map("subscriptions")
}

// ════════════════════════════════════════════════════════════════════════════
// LOCATION + BAY
// ════════════════════════════════════════════════════════════════════════════

enum LocationStatus {
  active
  disabled
}

model Location {
  id           String                                @id @default(cuid())
  tenantId     String
  tenant       Tenant                                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name         String
  address      String
  latitude     Float
  longitude    Float
  // PostGIS column kept in sync with lat/lng by application code.
  // Used for fast spatial queries (e.g. "carwashes within 5km").
  geom         Unsupported("geometry(Point, 4326)")?
  contactPhone String?
  workingHours Json? // schema: { mon: {open,close}|null, tue: ..., ... } OR null
  is24_7       Boolean                               @default(false)
  status       LocationStatus                        @default(active)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  bays         Bay[]
  photos       LocationPhoto[]
  transactions Transaction[]

  @@index([tenantId])
  @@index([status])
  @@index([deletedAt])
  @@map("locations")
}

model LocationPhoto {
  id         String   @id @default(cuid())
  locationId String
  location   Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  url        String
  sortOrder  Int      @default(0)
  isHero     Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([locationId, sortOrder])
  @@map("location_photos")
}

enum BayStatus {
  active
  disabled
}

model Bay {
  id                 String    @id @default(cuid())
  locationId         String
  location           Location  @relation(fields: [locationId], references: [id], onDelete: Restrict)
  tenantId           String
  tenant             Tenant    @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  name               String
  hardwareIdentifier String?   @unique
  qrShortId          String    @unique
  status             BayStatus @default(active)

  // Hardware bridge — обновляется при каждом heartbeat от Pico
  lastSeenAt     DateTime? // когда Pico последний раз вышел на связь
  lastRelayState Json?     // snapshot реле { fn2: 0, fn3: 1, ... }

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  transactions    Transaction[]
  hardwareEvents  HardwareEvent[]

  @@index([locationId])
  @@index([tenantId])
  @@map("bays")
}

// ════════════════════════════════════════════════════════════════════════════
// CUSTOMER
// ════════════════════════════════════════════════════════════════════════════

enum CustomerLanguage {
  az
  ru
  en
}

model Customer {
  id           String           @id @default(cuid())
  phone        String           @unique
  name         String?
  language     CustomerLanguage @default(az)
  city         String?
  pushToken    String?
  pushPlatform String? // "ios" | "android"

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  savedCards    SavedCard[]
  favorites     Favorite[]
  transactions  Transaction[]
  refreshTokens CustomerRefreshToken[]
  notifications CustomerNotification[]

  @@index([city])
  @@index([language])
  @@index([deletedAt])
  @@map("customers")
}

model CustomerNotification {
  // Per-customer in-app inbox row. Written when a super-admin broadcast is
  // delivered (one row per targeted customer); future transactional types
  // (receipts, hardware errors) reuse this table with a different `type`.
  id                 String    @id @default(cuid())
  customerId         String
  customer           Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  pushNotificationId String? // source broadcast; null for transactional
  type               String    @default("broadcast") // broadcast | promo | system | transaction
  titleAz            String
  titleRu            String
  titleEn            String
  bodyAz             String    @db.Text
  bodyRu             String    @db.Text
  bodyEn             String    @db.Text
  readAt             DateTime?
  createdAt          DateTime  @default(now())

  @@index([customerId, createdAt(sort: Desc)])
  @@index([customerId, readAt])
  @@map("customer_notifications")
}

enum CardBrand {
  visa
  mastercard
  unionpay
  maestro
  unknown
}

model SavedCard {
  id          String    @id @default(cuid())
  customerId  String
  customer    Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  ePointToken String    @unique
  brand       CardBrand @default(unknown)
  lastFour    String
  isDefault   Boolean   @default(false)
  createdAt   DateTime  @default(now())

  @@index([customerId])
  @@map("saved_cards")
}

model Favorite {
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@id([customerId, tenantId])
  @@index([customerId])
  @@index([tenantId])
  @@map("favorites")
}

// ════════════════════════════════════════════════════════════════════════════
// TRANSACTION
// ════════════════════════════════════════════════════════════════════════════

enum TransactionStatus {
  pending // created, awaiting ePoint authorization
  paid_crediting // bank approved, waiting for hardware ACK
  paid_credited // hardware confirmed — successful end-to-end
  paid_hardware_error // bank approved but hardware never confirmed (30s timeout)
  declined // bank declined
  cancelled // user cancelled in ePoint sheet
}

enum PaymentMethod {
  card
  apple_pay
  google_pay
  cash // купюроприёмник (offline payment через Pico)
}

model Transaction {
  id         String    @id @default(cuid())
  customerId String? // null after account deletion (anonymized)
  customer   Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  bayId      String
  bay        Bay       @relation(fields: [bayId], references: [id], onDelete: Restrict)
  locationId String
  location   Location  @relation(fields: [locationId], references: [id], onDelete: Restrict)
  tenantId   String
  tenant     Tenant    @relation(fields: [tenantId], references: [id], onDelete: Restrict)

  amountAzn          Decimal           @db.Decimal(10, 2)
  status             TransactionStatus @default(pending)
  ePointReference    String?           @unique
  paymentMethod      PaymentMethod?
  cardBrand          CardBrand?
  cardLastFour       String?
  hardwareCreditedAt DateTime?
  errorReason        String?           @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([customerId, createdAt(sort: Desc)])
  @@index([tenantId, createdAt(sort: Desc)])
  @@index([bayId, createdAt(sort: Desc)])
  @@index([status])
  @@map("transactions")
}

// ════════════════════════════════════════════════════════════════════════════
// HARDWARE EVENTS (ежедневный отчёт от Pico)
// ════════════════════════════════════════════════════════════════════════════

model HardwareEvent {
  // Одна строка = одно событие из daily_report Pico.
  // eventType:
  //   "cash"    — принята купюра (купюроприёмник, наличные)
  //   "online"  — онлайн-оплата через эмуляцию импульсов
  //   "usage"   — мониторинг: какая программа запустилась и сколько длилась
  //   "anomaly" — слишком много импульсов подряд (помеха/сбой)
  id              String   @id @default(cuid())
  bayId           String
  bay             Bay      @relation(fields: [bayId], references: [id], onDelete: Restrict)
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  eventType       String   // "cash" | "online" | "usage" | "anomaly"
  amountAzn       Decimal? @db.Decimal(10, 2)
  pulses          Int?
  txId            String?  // Transaction.id для online-событий
  programName     String?
  durationSeconds Int?     // для usage-событий
  relayCombo      String[] // комбинация активных реле для usage
  reportDate      String   // "YYYY-MM-DD" — день отчёта (по времени Баку)
  rawTs           String   // ISO-таймстамп от Pico (Asia/Baku)
  createdAt       DateTime @default(now())

  @@index([bayId, reportDate])
  @@index([tenantId, reportDate])
  @@map("hardware_events")
}

// ════════════════════════════════════════════════════════════════════════════
// PROMO + PUSH + FEATURED
// ════════════════════════════════════════════════════════════════════════════

enum PromoStatus {
  draft
  scheduled
  active
  expired
}

model Promo {
  id             String      @id @default(cuid())
  imageUrl       String? // optional — a promo can be a colored gradient banner with no photo
  theme          String? // banner color when image-less: "blue" | "violet" | "teal" | "amber"
  sortOrder      Int         @default(0) // super-admin-controlled carousel order (asc)
  titleAz        String
  titleRu        String
  titleEn        String
  bodyAz         String      @db.Text
  bodyRu         String      @db.Text
  bodyEn         String      @db.Text
  ctaTextAz      String?
  ctaTextRu      String?
  ctaTextEn      String?
  ctaTargetType  String? // "tenant" | "external_url" | null
  ctaTargetValue String? // tenantId or URL
  startAt        DateTime
  endAt          DateTime
  status         PromoStatus @default(draft)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@index([status, startAt, endAt])
  @@map("promos")
}

model PushNotification {
  id              String    @id @default(cuid())
  titleAz         String
  titleRu         String
  titleEn         String
  bodyAz          String    @db.Text
  bodyRu          String    @db.Text
  bodyEn          String    @db.Text
  targetType      String // "all" | "city" | "language"
  targetValues    String[] // cities or language codes; empty for "all"
  scheduledFor    DateTime?
  sentAt          DateTime?
  recipientsCount Int       @default(0)
  deliveredCount  Int       @default(0)
  createdAt       DateTime  @default(now())

  @@index([sentAt(sort: Desc)])
  @@map("push_notifications")
}

model FeaturedTenant {
  tenantId  String   @id
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  @@index([sortOrder])
  @@map("featured_tenants")
}

// ════════════════════════════════════════════════════════════════════════════
// PLATFORM CONFIG
// ════════════════════════════════════════════════════════════════════════════

enum AppPlatform {
  ios
  android
}

model AppVersion {
  platform       AppPlatform @id
  latestVersion  String
  minimumVersion String
  releaseNotes   String?     @db.Text
  updatedAt      DateTime    @updatedAt

  @@map("app_versions")
}

model AuditLog {
  id           String   @id @default(cuid())
  actorType    String // "super_admin" | "tenant" | "system"
  actorId      String?
  action       String // e.g. "tenant.suspend", "promo.create"
  resourceType String // e.g. "tenant", "promo", "bay"
  resourceId   String?
  changes      Json?
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime @default(now())

  @@index([actorType, actorId, createdAt(sort: Desc)])
  @@index([resourceType, resourceId, createdAt(sort: Desc)])
  @@index([createdAt(sort: Desc)])
  @@map("audit_logs")
}

// ════════════════════════════════════════════════════════════════════════════
// FILE UPLOADS (Cloudflare R2)
// ════════════════════════════════════════════════════════════════════════════

model UploadedFile {
  // Tracks files uploaded to R2 so we can detect + clean orphans.
  id           String   @id @default(cuid())
  key          String   @unique // R2 object key
  url          String // public CDN URL
  mimeType     String
  sizeBytes    Int
  context      String? // "tenant_logo" | "tenant_photo" | "location_photo" | "promo_image"
  uploadedBy   String? // "super_admin" | "tenant" | "system"
  uploadedById String?
  createdAt    DateTime @default(now())

  @@index([context, createdAt(sort: Desc)])
  @@index([uploadedBy, uploadedById])
  @@map("uploaded_files")
}

// ════════════════════════════════════════════════════════════════════════════
// PLATFORM SETTINGS
// ════════════════════════════════════════════════════════════════════════════

model PlatformSetting {
  // Super-admin-editable platform settings. Key-value table — adding a
  // new setting key takes no migration; the admin UI is the only
  // consumer and treats values as named strings.
  //
  // Known keys (defined in code, single source of truth in
  // super-admin/settings/settings.constants.ts):
  //   tahawash.logoUrl          string (URL)
  //   tahawash.brandColor       string (hex #RRGGBB)
  //   support.whatsappNumber    string (+994XXXXXXXXX)
  //   support.email             string (email)
  //   support.hours             string (free text)
  key       String   @id
  value     String   @db.Text
  updatedAt DateTime @updatedAt

  @@map("platform_settings")
}

// ════════════════════════════════════════════════════════════════════════════
// LEGAL DOCUMENTS (T&C + Privacy, versioned)
// ════════════════════════════════════════════════════════════════════════════

model LegalDocument {
  // Versioned legal documents (Terms of Service + Privacy Policy) in
  // AZ/RU/EN. Super-admin publishes new versions via the admin UI; the
  // mobile app reads the current version via /public/legal/:type.
  //
  // Versioning model:
  //   - `version` is monotonic per (type, language). Publishing a new
  //     version increments it and flips the previous current row's
  //     isCurrent=false in the same transaction.
  //   - At most one row per (type, language) has isCurrent=true.
  //     Enforced application-side in a $transaction (Prisma doesn't
  //     model partial-unique indexes; at single-super-admin MVP scale
  //     the invariant is safe).
  //
  // Body format:
  //   sections JSON = [{ heading: string, body: string }, ...]
  //   Matches the mobile legal screen's per-section card rendering
  //   (apps/mobile/app/legal/[type].tsx). Editor is a list of rows.
  id          String   @id @default(cuid())
  type        String // "terms" | "privacy"
  language    String // "az" | "ru" | "en"
  version     Int
  sections    Json // [{ heading, body }, ...]
  publishedAt DateTime @default(now())
  publishedBy String? // SuperAdminUser.id
  isCurrent   Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@unique([type, language, version])
  @@index([type, language, isCurrent])
  @@index([type, language, version(sort: Desc)])
  @@map("legal_documents")
}
