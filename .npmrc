# Tahawash — pnpm config
#
# Metro (used by Expo / React Native) does NOT understand pnpm's symlinked
# node_modules tree natively. It expects to find dependencies in
# `node_modules/<package>` style. We use `public-hoist-pattern` to hoist
# React Native / Expo / Babel runtime packages to the workspace root,
# making Metro happy.
#
# This does NOT affect strictness of `pnpm install` for the backend or
# admin — those workspaces still get exactly what their package.json
# declares. We're only hoisting things that Metro needs to RESOLVE.
#
# See: https://docs.expo.dev/guides/monorepos/#use-the-pnpm-and-yarn-pnp-package-managers

node-linker=isolated

public-hoist-pattern[]=*babel*
public-hoist-pattern[]=@babel/*
public-hoist-pattern[]=*react-native*
public-hoist-pattern[]=@react-native*
public-hoist-pattern[]=*expo*
public-hoist-pattern[]=@expo/*
public-hoist-pattern[]=*metro*
public-hoist-pattern[]=@metro/*
public-hoist-pattern[]=*nativewind*
public-hoist-pattern[]=@nativewind/*

# Suppress noise about peer deps from older eslint-config-expo
strict-peer-dependencies=false
