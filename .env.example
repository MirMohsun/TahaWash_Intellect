# ─────────────────────────────────────────────────────────
# Tahawash — example environment variables
# Copy this file to `.env` and fill in real values.
# NEVER commit `.env` — it is gitignored.
# ─────────────────────────────────────────────────────────

NODE_ENV=development

# ── Backend (NestJS) ─────────────────────────────────────
PORT=3000
DATABASE_URL=postgresql://postgres:postgres@localhost:5434/tahawash
REDIS_URL=redis://localhost:6379

# JWT
JWT_ACCESS_SECRET=change-me-strong-random-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-different-strong-random-secret
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=30d

# ── SMS Provider (Azerbaijan local — TBD) ────────────────
SMS_PROVIDER=mock
SMS_API_KEY=
SMS_SENDER_ID=Tahawash

# ── Payments (ePoint — docs pending from user) ───────────
EPOINT_API_BASE=
EPOINT_PUBLIC_KEY=
EPOINT_PRIVATE_KEY=

# ── Storage (Cloudflare R2) ──────────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=tahawash-files
R2_ENDPOINT=
R2_PUBLIC_URL=

# ── Email (Resend) ───────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@tahawash.az
RESEND_FROM_NAME=Tahawash

# ── Push notifications (Firebase Cloud Messaging) ────────
FCM_SERVICE_ACCOUNT_JSON=

# ── Monitoring & analytics ───────────────────────────────
SENTRY_DSN_BACKEND=
SENTRY_DSN_MOBILE=
SENTRY_DSN_ADMIN=
POSTHOG_API_KEY=
POSTHOG_HOST=https://eu.posthog.com

# ── Hardware MQTT (Phase 5+) ─────────────────────────────
MQTT_BROKER_URL=
MQTT_USERNAME=
MQTT_PASSWORD=

# ── Mobile app (Expo public env — prefixed EXPO_PUBLIC_) ─
EXPO_PUBLIC_API_URL=http://localhost:3000
EXPO_PUBLIC_MAPBOX_TOKEN=
EXPO_PUBLIC_SENTRY_DSN=
EXPO_PUBLIC_POSTHOG_API_KEY=
EXPO_PUBLIC_SUPPORT_WHATSAPP=

# ── Web admin (Vite public env — prefixed VITE_) ─────────
VITE_API_URL=http://localhost:3000
VITE_MAPBOX_TOKEN=
VITE_SENTRY_DSN=
VITE_POSTHOG_API_KEY=
